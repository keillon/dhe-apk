generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum EquipmentStatus {
  operando
  parado
  manutencao
}

enum OilContamination {
  baixa
  media
  alta
}

enum NotificationType {
  inspecao_pendente
  manutencao_vencida
  oleo_contaminado
}

enum PhotoType {
  antes
  depois
}

enum MediaKind {
  image
  video
}

enum UserRole {
  admin
  tecnico
}

enum RouteStatus {
  planejada
  em_andamento
  concluida
}

enum AuditEntity {
  equipamento
  cliente
}

model Usuario {
  id         String   @id @default(cuid())
  email      String   @unique
  senhaHash  String   @map("senha_hash")
  nome       String
  cargo      String   @default("Técnico")
  empresa    String   @default("DHE Componentes Hidráulicos")
  role       UserRole @default(tecnico)
  fotoUrl    String?  @map("foto_url")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  inspecoes           Inspecao[]
  historicos          Historico[]
  notificacoes        Notificacao[]
  pushTokens          PushToken[]
  rotasDiarias        RotaDiaria[]
  passwordResetTokens PasswordResetToken[]
  auditLogs           AuditLog[]

  @@map("usuarios")
}

model Cliente {
  id        String   @id @default(cuid())
  nome      String
  empresa   String
  email     String?
  telefone  String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  equipamentos Equipamento[]

  @@map("clientes")
}

model Equipamento {
  id                String          @id @default(cuid())
  qrCode            String          @unique @map("qr_code")
  clienteId         String          @map("cliente_id")
  empresa           String
  nome              String
  patrimonio        String
  marca             String
  modelo            String
  numeroSerie       String          @map("numero_serie")
  ano               Int
  localizacao       String
  tipo              String?
  fotoUrl           String?         @map("foto_url")
  status            EquipmentStatus @default(operando)
  ultimaInspecao    DateTime?       @map("ultima_inspecao")
  proximaManutencao DateTime?       @map("proxima_manutencao")
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")

  cliente      Cliente       @relation(fields: [clienteId], references: [id])
  inspecoes    Inspecao[]
  historicos   Historico[]
  notificacoes Notificacao[]
  rotaItens    RotaItem[]

  @@index([clienteId])
  @@index([status])
  @@index([patrimonio])
  @@index([proximaManutencao])
  @@map("equipamentos")
}

model Inspecao {
  id                 String           @id @default(cuid())
  clientRequestId    String?          @unique @map("client_request_id")
  equipamentoId      String           @map("equipamento_id")
  tecnicoId          String           @map("tecnico_id")
  nivelOleo          Int              @map("nivel_oleo")
  contaminacaoOleo   OilContamination @map("contaminacao_oleo")
  dataUltimaLimpeza  DateTime?        @map("data_ultima_limpeza") @db.Date
  complemento        String?
  checklist          Json             @default("{}")
  createdAt          DateTime         @default(now()) @map("created_at")

  equipamento Equipamento @relation(fields: [equipamentoId], references: [id])
  tecnico     Usuario     @relation(fields: [tecnicoId], references: [id])
  fotos       Foto[]
  assinatura  Assinatura?
  historico   Historico?

  @@index([equipamentoId])
  @@index([tecnicoId])
  @@index([createdAt(sort: Desc)])
  @@map("inspecoes")
}

model Historico {
  id            String   @id @default(cuid())
  inspecaoId    String   @unique @map("inspecao_id")
  equipamentoId String   @map("equipamento_id")
  tecnicoId     String   @map("tecnico_id")
  dados         Json
  createdAt     DateTime @default(now()) @map("created_at")

  inspecao    Inspecao    @relation(fields: [inspecaoId], references: [id])
  equipamento Equipamento @relation(fields: [equipamentoId], references: [id])
  tecnico     Usuario     @relation(fields: [tecnicoId], references: [id])

  @@index([equipamentoId])
  @@map("historico")
}

model Foto {
  id         String    @id @default(cuid())
  inspecaoId String    @map("inspecao_id")
  url        String
  tipo       PhotoType
  mediaKind  MediaKind @default(image) @map("media_kind")
  createdAt  DateTime  @default(now()) @map("created_at")

  inspecao Inspecao @relation(fields: [inspecaoId], references: [id])

  @@map("fotos")
}

model Assinatura {
  id         String   @id @default(cuid())
  inspecaoId String   @unique @map("inspecao_id")
  url        String
  createdAt  DateTime @default(now()) @map("created_at")

  inspecao Inspecao @relation(fields: [inspecaoId], references: [id])

  @@map("assinaturas")
}

model Notificacao {
  id            String           @id @default(cuid())
  usuarioId     String           @map("usuario_id")
  equipamentoId String?          @map("equipamento_id")
  tipo          NotificationType
  titulo        String
  mensagem      String
  lida          Boolean          @default(false)
  pushSentAt    DateTime?        @map("push_sent_at")
  createdAt     DateTime         @default(now()) @map("created_at")

  usuario     Usuario      @relation(fields: [usuarioId], references: [id])
  equipamento Equipamento? @relation(fields: [equipamentoId], references: [id])

  @@index([usuarioId])
  @@index([lida])
  @@unique([usuarioId, equipamentoId, tipo], map: "notificacoes_usuario_equipamento_tipo_uidx")
  @@map("notificacoes")
}

model PushToken {
  id        String   @id @default(cuid())
  usuarioId String   @map("usuario_id")
  token     String   @unique
  platform  String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId])
  @@map("push_tokens")
}

model ChecklistTemplate {
  id        String   @id @default(cuid())
  tipo      String   @unique
  nome      String
  itens     Json
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("checklist_templates")
}

model RotaDiaria {
  id        String      @id @default(cuid())
  tecnicoId String      @map("tecnico_id")
  data      DateTime    @db.Date
  status    RouteStatus @default(planejada)
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")

  tecnico Usuario    @relation(fields: [tecnicoId], references: [id], onDelete: Cascade)
  itens   RotaItem[]

  @@unique([tecnicoId, data])
  @@map("rotas_diarias")
}

model RotaItem {
  id            String    @id @default(cuid())
  rotaId        String    @map("rota_id")
  equipamentoId String    @map("equipamento_id")
  ordem         Int
  visitadoEm    DateTime? @map("visitado_em")
  createdAt     DateTime  @default(now()) @map("created_at")

  rota        RotaDiaria  @relation(fields: [rotaId], references: [id], onDelete: Cascade)
  equipamento Equipamento @relation(fields: [equipamentoId], references: [id], onDelete: Cascade)

  @@index([rotaId])
  @@map("rota_itens")
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  usuarioId String    @map("usuario_id")
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId])
  @@map("password_reset_tokens")
}

model AuditLog {
  id         String      @id @default(cuid())
  entidade   AuditEntity
  entidadeId String      @map("entidade_id")
  usuarioId  String      @map("usuario_id")
  acao       String
  antes      Json?
  depois     Json?
  createdAt  DateTime    @default(now()) @map("created_at")

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([entidade, entidadeId])
  @@map("audit_logs")
}
