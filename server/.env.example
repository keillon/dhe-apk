# Banco DHE — isolado, não exposto publicamente
DHE_DB_PASSWORD=altere_esta_senha_forte

# API
JWT_SECRET=altere_este_jwt_secret_longo_e_aleatorio
PORT=4002
NODE_ENV=production

# URL interna (usada pelo container da API)
DATABASE_URL=postgresql://dhe_app:${DHE_DB_PASSWORD}@dhe-postgres:5432/dhe_hidraulicos?schema=public

# Traefik (opcional — ajuste o domínio)
DHE_API_HOST=api-dhe.seudominio.com.br
