# Banco DHE — isolado, não exposto publicamente
DHE_DB_PASSWORD=altere_esta_senha_forte

# API
JWT_SECRET=altere_este_jwt_secret_longo_e_aleatorio
PORT=4002
NODE_ENV=production

# URL interna (usada pelo container da API)
DATABASE_URL=postgresql://dhe_app:${DHE_DB_PASSWORD}@dhe-postgres:5432/dhe_hidraulicos?schema=public

# Desenvolvimento local (com docker-compose.dev.yml — porta 5433 no host)
# DATABASE_URL=postgresql://dhe_app:${DHE_DB_PASSWORD}@localhost:5433/dhe_hidraulicos?schema=public

# Traefik — domínio precisa existir no DNS apontando para a VPS
DHE_API_HOST=api-dhe.dhepr.com.br
