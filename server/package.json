{
  "name": "dhe-api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:local": "node ./node_modules/prisma/build/index.js migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "db:vps:up": "docker compose -f docker-compose.vps.yml up -d --build --wait",
    "db:vps:start": "sh scripts/vps-up.sh",
    "db:vps:traefik": "docker compose -f docker-compose.vps-traefik.yml up -d --build",
    "db:vps:seed": "docker compose -f docker-compose.vps.yml exec dhe-api npx tsx prisma/seed.ts",
    "db:vps:migrate": "docker compose -f docker-compose.vps.yml exec dhe-api npx prisma migrate deploy",
    "db:vps:logs": "docker compose -f docker-compose.vps.yml logs -f dhe-api",
    "test:db": "tsx scripts/test-connection.ts"
  },
  "dependencies": {
    "@prisma/client": "6.19.3",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "prisma": "6.19.3",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
