{
  "expo": {
    "name": "DHE Hidráulicos",
    "slug": "dhe-hidraulicos",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "dhe",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/logo-dhe-white.webp",
      "resizeMode": "contain",
      "backgroundColor": "#001423"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.dhepr.hidraulicos"
    },
    "android": {
      "package": "com.dhepr.hidraulicos",
      "usesCleartextTraffic": true,
      "adaptiveIcon": {
        "backgroundColor": "#001423",
        "foregroundImage": "./assets/icon.png"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Permitir que o DHE acesse a câmera para escanear QR Codes dos equipamentos."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Permitir que o DHE acesse fotos para registrar inspeções."
        }
      ],
      "expo-secure-store",
      "expo-screen-orientation",
      "expo-video",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Permitir que o DHE use Face ID para desbloquear o aplicativo."
        }
      ],
      [
        "expo-notifications",
        {
          "defaultChannel": "default"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "1129fcc8-ea00-40d6-8e31-4d88a9fb4060"
      }
    },
    "owner": "keillon"
  }
}
