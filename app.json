{
  "expo": {
    "name": "DHE Hidráulicos",
    "slug": "dhe-hidraulicos",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "dhe",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#001423"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.dhepr.hidraulicos",
      "icon": "./assets/appstore.png"
    },
    "android": {
      "package": "com.dhepr.hidraulicos",
      "usesCleartextTraffic": true,
      "softwareKeyboardLayoutMode": "resize",
      "navigationBarColor": "#000A14",
      "adaptiveIcon": {
        "backgroundColor": "#0172FE",
        "foregroundImage": "./assets/adaptive-icon.png",
        "monochromeImage": "./assets/monochrome-icon.png"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ]
    },
    "androidNavigationBar": {
      "backgroundColor": "#000A14",
      "barStyle": "light-content"
    },
    "backgroundColor": "#000A14",
    "primaryColor": "#0172FE",
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "name": "DHE Hidráulicos",
      "shortName": "DHE",
      "themeColor": "#0172FE",
      "backgroundColor": "#001423"
    },
    "plugins": [
      "./plugins/withCleartextTraffic.js",
      "expo-router",
      "expo-system-ui",
      [
        "expo-navigation-bar",
        {
          "backgroundColor": "#000A14",
          "style": "light",
          "borderColor": "#000A14"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Permitir que o DHE acesse a câmera para escanear QR Codes dos equipamentos."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Permitir que o DHE acesse fotos para registrar inspeções."
        }
      ],
      "expo-secure-store",
      "expo-screen-orientation",
      "expo-video",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Permitir que o DHE use Face ID para desbloquear o aplicativo."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#0172FE",
          "defaultChannel": "default",
          "sounds": []
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 220,
          "resizeMode": "contain",
          "backgroundColor": "#001423"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "1129fcc8-ea00-40d6-8e31-4d88a9fb4060"
      }
    },
    "owner": "keillon"
  }
}
